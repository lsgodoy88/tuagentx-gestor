generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id              String          @id @default(cuid())
  nombre          String
  email           String          @unique
  password        String
  plan            String          @default("basico")
  activo          Boolean         @default(true)
  maxSupervisores Int             @default(1)
  maxVendedores   Int             @default(1)
  maxEntregas     Int             @default(0)
  maxBodega       Int             @default(0)
  maxImpulsadoras Int             @default(0)
  createdAt       DateTime        @default(now())
  planFin         DateTime?       @db.Timestamp(6)
  telefono        String?         @db.VarChar(20)
  modoEquipo      String?
  horaInicioRuta  String          @default("06:00")
  horaFinRuta     String          @default("20:00")
  autoCrearRuta   Boolean         @default(false)
  autoCerrarRuta  Boolean         @default(false)
  diasCrearRuta   String          @default("0,1,2,3,4")
  diasCerrarRuta  String          @default("0,1,2,3,4")
  ciudadEntregaLocal   String?
  diasHistorialBodega  Int             @default(7)
  bodegaPuedeEnviar    Boolean         @default(false)
  ultimaSyncBodega     DateTime?
  configRecibos   Json?           @default("{\"nit\": null, \"logo\": null, \"prefijo\": \"REC\", \"telefono\": null, \"direccion\": null, \"anchoPapel\": \"80mm\"}")
  chatsAsistente  AsistenteChat[]
  Cartera         Cartera[]
  clientes        Cliente[]
  empleados       Empleado[]
  rutas           Ruta[]
  rutasFijas      RutaFija[]
  metasRecaudo    MetaRecaudo[]
  subEmpresas     SubEmpresa[]
  integraciones   Integracion[]
  CarteraCache    CarteraCache[]
  vinculadas      EmpresaVinculada[]
  ordenesDespacho OrdenDespacho[]
}

model Empleado {
  id                  String               @id @default(cuid())
  nombre              String
  email               String               @unique
  password            String
  telefono            String?
  rol                 String               @default("vendedor")
  activo              Boolean              @default(true)
  vendedorId          String?
  empresaId           String
  createdAt           DateTime             @default(now())
  puedeCapturarGps    Boolean              @default(false)
  ciudades            String[]             @default([])
  permisos            Json?                @default("{}")
  etiqueta            String?
  uptresEmail         String?
  uptresPassword      String?
  apiId               String?
  subEmpresaId        String?
  configRecibos       Json?                @default("{\"prefijo\": null, \"anchoPapel\": null, \"consecutivoMes\": null, \"consecutivoActual\": 0, \"usarConfigEmpresa\": true}")
  Cartera             Cartera[]
  DetalleCartera      DetalleCartera[]
  empresa             Empresa              @relation(fields: [empresaId], references: [id])
  subEmpresa          SubEmpresa?          @relation(fields: [subEmpresaId], references: [id])
  listasAsignadas     EmpleadoLista[]
  PagoCartera         PagoCartera[]
  rutas               RutaEmpleado[]
  rutasFijas          RutaFijaEmpleado[]
  vendedoresAsignados SupervisorVendedor[] @relation("SupervisorVendedores")
  metasRecaudo        MetaRecaudo[]
  supervisorAsignado  SupervisorVendedor[] @relation("VendedorSupervisor")
  turnos              Turno[]
  visitas             Visita[]
  ordenesAlistadas    OrdenDespacho[] @relation("AlistadoPor")
  ordenesRepartidas   OrdenDespacho[] @relation("RepartidorDespacho")

  @@map("Empleado")
}

model SupervisorVendedor {
  supervisorId String
  vendedorId   String
  supervisor   Empleado @relation("SupervisorVendedores", fields: [supervisorId], references: [id])
  vendedor     Empleado @relation("VendedorSupervisor", fields: [vendedorId], references: [id])

  @@id([supervisorId, vendedorId])
  @@map("SupervisorVendedor")
}

model Cliente {
  id              String            @id @default(cuid())
  nombre          String
  nombreComercial String?
  direccion       String?
  telefono        String?
  email           String?
  lat             Float?
  lng             Float?
  ubicacionReal   Boolean           @default(false)
  empresaId       String
  subEmpresaId    String?
  createdAt       DateTime          @default(now())
  metaVenta       Float?
  nit             String?           @db.VarChar(255)
  ciudad          String?           @db.VarChar(255)
  listaId         String?
  apiId           String?
  maps            String?
  latTmp          Float?
  lngTmp          Float?
  Cartera         Cartera[]
  empresa         Empresa           @relation(fields: [empresaId], references: [id])
  subEmpresa      SubEmpresa?       @relation(fields: [subEmpresaId], references: [id])
  lista           ListaClientes?    @relation(fields: [listaId], references: [id])
  rutaClientes    RutaCliente[]
  rutasFijas      RutaFijaCliente[]
  visitas         Visita[]

  @@index([empresaId], map: "idx_cliente_empresa")
  @@index([listaId], map: "idx_cliente_lista")
  @@index([nit], map: "idx_cliente_nit")
  @@index([nombre], map: "idx_cliente_nombre")
  @@map("Cliente")
}

model Turno {
  id         String    @id @default(cuid())
  empleadoId String
  inicio     DateTime  @default(now())
  fin        DateTime?
  latInicio  Float?
  lngInicio  Float?
  latFin     Float?
  lngFin     Float?
  activo     Boolean   @default(true)
  pausado        Boolean   @default(false)
  pausaInicio    DateTime?
  pausaMotivo    String?
  pausaDuracionMin Int?
  empleado   Empleado  @relation(fields: [empleadoId], references: [id])
  visitas    Visita[]

  @@index([empleadoId], map: "idx_turno_empleado")
  @@map("Turno")
}

model Visita {
  id                String    @id @default(cuid())
  empleadoId        String
  clienteId         String
  turnoId           String?
  lat               Float?
  lng               Float?
  nota              String?
  foto              String?
  tipo              String    @default("visita")
  monto             Float?
  fechaBogota       DateTime?
  esLibre           Boolean   @default(false)
  factura           String?
  firma             String?
  rutaFijaClienteId String?
  ordenDespachoId   String?
  createdAt         DateTime  @default(now())
  cliente           Cliente   @relation(fields: [clienteId], references: [id])
  empleado          Empleado  @relation(fields: [empleadoId], references: [id])
  turno             Turno?    @relation(fields: [turnoId], references: [id])
  ordenDespacho     OrdenDespacho? @relation(fields: [ordenDespachoId], references: [id])

  @@index([empleadoId], map: "idx_visita_empleado")
  @@index([empleadoId, clienteId], map: "idx_visita_empleado_cliente")
  @@index([createdAt], map: "idx_visita_fecha")
  @@index([fechaBogota], map: "idx_visita_fecha_bogota")
  @@index([fechaBogota], map: "idx_visita_fechabogota")
  @@map("Visita")
}

model Ruta {
  id                 String            @id @default(cuid())
  nombre             String
  fecha              DateTime?
  empresaId          String
  subEmpresaId       String?
  empresaVinculadaId String?
  createdAt          DateTime          @default(now())
  cerrada            Boolean           @default(false)
  cerradaEl          DateTime?
  empresa            Empresa           @relation(fields: [empresaId], references: [id])
  subEmpresa         SubEmpresa?       @relation(fields: [subEmpresaId], references: [id])
  empresaVinculada   EmpresaVinculada? @relation(fields: [empresaVinculadaId], references: [id])
  clientes           RutaCliente[]
  empleados          RutaEmpleado[]

  @@index([empresaId], map: "idx_ruta_empresa")
  @@map("Ruta")
}

model RutaEmpleado {
  id         String   @id @default(cuid())
  rutaId     String
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  ruta       Ruta     @relation(fields: [rutaId], references: [id])

  @@map("RutaEmpleado")
}

model RutaCliente {
  id                 String   @id @default(cuid())
  rutaId             String
  clienteId          String
  orden              Int      @default(0)
  rezago             Boolean  @default(false)
  asignadoEn         DateTime @default(now())
  supervisorId       String?
  supervisorEtiqueta String?
  notas              String?
  ejecutado          Boolean  @default(false)
  cliente            Cliente  @relation(fields: [clienteId], references: [id])
  ruta               Ruta     @relation(fields: [rutaId], references: [id])

  @@index([rutaId], map: "idx_rutacliente_ruta")
  @@map("RutaCliente")
}

model RutaFija {
  id           String             @id @default(cuid())
  nombre       String
  diaSemana    Int
  empresaId    String
  subEmpresaId String?
  createdAt    DateTime           @default(now())
  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  subEmpresa   SubEmpresa?        @relation(fields: [subEmpresaId], references: [id])
  clientes     RutaFijaCliente[]
  empleados    RutaFijaEmpleado[]

  @@map("RutaFija")
}

model RutaFijaEmpleado {
  id         String   @id @default(cuid())
  rutaFijaId String
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id])
  rutaFija   RutaFija @relation(fields: [rutaFijaId], references: [id])

  @@map("RutaFijaEmpleado")
}

model RutaFijaCliente {
  id         String   @id @default(cuid())
  rutaFijaId String
  clienteId  String
  orden      Int      @default(0)
  metaVenta  Float?
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  rutaFija   RutaFija @relation(fields: [rutaFijaId], references: [id])

  @@map("RutaFijaCliente")
}

model AuditLog {
  id         String   @id @default(cuid())
  accion     String
  usuario    String?
  detalle    String?
  empleadoId String?
  empresaId  String?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("AuditLog")
}

model PrecioRol {
  id        String   @id @default(cuid())
  rol       String   @unique
  precio    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("PrecioRol")
}

model ListaClientes {
  id         String          @id @default(cuid())
  nombre     String
  empresaId  String
  createdAt  DateTime?       @default(now()) @db.Timestamp(6)
  clientes   Cliente[]
  vendedores EmpleadoLista[]

  @@map("ListaClientes")
}

model EmpleadoLista {
  empleadoId String
  listaId    String
  empleado   Empleado      @relation(fields: [empleadoId], references: [id])
  lista      ListaClientes @relation(fields: [listaId], references: [id])

  @@id([empleadoId, listaId])
  @@map("EmpleadoLista")
}

model AsistenteChat {
  id        String    @id @default(cuid())
  empresaId String
  rol       String
  texto     String
  creadoEn  DateTime? @default(now()) @db.Timestamp(6)
  empresa   Empresa   @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Cartera {
  id             String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  clienteId      String
  empresaId      String
  saldoTotal     Decimal?         @default(0) @db.Decimal(12, 2)
  saldoPendiente Decimal?         @default(0) @db.Decimal(12, 2)
  fuente         String?          @default("manual")
  updatedAt      DateTime?        @default(now()) @db.Timestamp(6)
  createdAt      DateTime?        @default(now()) @db.Timestamp(6)
  celular        String?
  empleadoId     String?
  Cliente        Cliente          @relation(fields: [clienteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Empleado       Empleado?        @relation(fields: [empleadoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Empresa        Empresa          @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  DetalleCartera DetalleCartera[]
  PagoCartera    PagoCartera[]
}

model DetalleCartera {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  carteraId        String
  numeroFactura    String?
  valor            Decimal   @db.Decimal(12, 2)
  fechaVencimiento DateTime? @db.Date
  estado           String?   @default("pendiente")
  createdAt        DateTime? @default(now()) @db.Timestamp(6)
  celular          String?
  concepto         String?
  valorFactura     Decimal?  @db.Decimal(12, 2)
  abonos           Decimal?  @default(0) @db.Decimal(12, 2)
  empleadoId       String?
  Cartera          Cartera   @relation(fields: [carteraId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Empleado         Empleado? @relation(fields: [empleadoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PagoCartera {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  carteraId    String
  empleadoId   String
  monto        Decimal   @db.Decimal(12, 2)
  descuento    Decimal?  @default(0) @db.Decimal(12, 2)
  tipo         String?   @default("abono")
  metodopago   String?   @default("efectivo")
  notas        String?
  reciboUrl    String?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  numeroRecibo String?
  reciboToken    String?  @unique
  tokenExpira    DateTime?
  voucherKey     String?
  voucherDatosIA Json?
  syncDeudaId    String?
  envioEstado    String    @default("pendiente")
  envioFecha     DateTime?
  envioRef       String?
  envioVariacion Json?
  Cartera        Cartera   @relation(fields: [carteraId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Empleado       Empleado  @relation(fields: [empleadoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PushSuscripcion {
  id         String   @id
  empleadoId String
  endpoint   String
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([empleadoId])
}

model nc_api_tokens {
  id               Int       @id @default(autoincrement())
  base_id          String?   @db.VarChar(20)
  db_alias         String?   @db.VarChar(255)
  description      String?   @db.VarChar(255)
  permissions      String?
  token            String?
  expiry           String?   @db.VarChar(255)
  enabled          Boolean?  @default(true)
  fk_user_id       String?   @db.VarChar(20)
  fk_workspace_id  String?   @db.VarChar(20)
  fk_sso_client_id String?   @db.VarChar(20)
  created_at       DateTime? @db.Timestamptz(6)
  updated_at       DateTime? @db.Timestamptz(6)

  @@index([fk_sso_client_id], map: "nc_api_tokens_fk_sso_client_id_index")
  @@index([fk_user_id], map: "nc_api_tokens_fk_user_id_index")
}

model nc_audit_v2 {
  id              String   @id(map: "nc_audit_v2_pkx") @db.Uuid
  user            String?  @db.VarChar(255)
  ip              String?  @db.VarChar(255)
  source_id       String?  @db.VarChar(20)
  base_id         String?  @db.VarChar(20)
  fk_model_id     String?  @db.VarChar(20)
  row_id          String?  @db.VarChar(255)
  op_type         String?  @db.VarChar(255)
  op_sub_type     String?  @db.VarChar(255)
  status          String?  @db.VarChar(255)
  description     String?
  details         String?
  fk_user_id      String?  @db.VarChar(20)
  fk_ref_id       String?  @db.VarChar(20)
  fk_parent_id    String?  @db.Uuid
  fk_workspace_id String?  @db.VarChar(20)
  fk_org_id       String?  @db.VarChar(20)
  user_agent      String?
  version         Int?     @default(0) @db.SmallInt
  old_id          String?  @db.VarChar(20)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([fk_workspace_id], map: "nc_audit_v2_fk_workspace_idx")
  @@index([old_id], map: "nc_audit_v2_old_id_index")
  @@index([base_id, fk_workspace_id], map: "nc_audit_v2_tenant_idx")
  @@index([base_id, fk_model_id, row_id, fk_workspace_id], map: "nc_record_audit_v2_tenant_idx")
}

model nc_automation_executions {
  id                String    @db.VarChar(20)
  fk_workspace_id   String?   @db.VarChar(20)
  base_id           String    @db.VarChar(20)
  fk_workflow_id    String    @db.VarChar(20)
  workflow_data     String?
  execution_data    String?
  finished          Boolean?  @default(false)
  started_at        DateTime? @db.Timestamptz(6)
  finished_at       DateTime? @db.Timestamptz(6)
  status            String?   @db.VarChar(50)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  resume_at         DateTime? @db.Timestamptz(6)
  error_notified_at DateTime? @db.Timestamptz(6)

  @@id([base_id, id])
  @@index([status, error_notified_at], map: "nc_automation_executions_error_notify_idx")
  @@index([id], map: "nc_automation_executions_oldpk_idx")
  @@index([fk_workspace_id, base_id, resume_at], map: "nc_automation_executions_resume_idx")
  @@index([base_id, fk_workspace_id], map: "nc_workflow_executions_context_idx")
  @@index([fk_workflow_id], map: "nc_workflow_executions_workflow_idx")
}

model nc_automation_subscribers {
  id               String   @db.VarChar(20)
  fk_workspace_id  String?  @db.VarChar(20)
  base_id          String   @db.VarChar(20)
  fk_automation_id String?  @db.VarChar(20)
  fk_user_id       String?  @db.VarChar(20)
  notify_on_error  Boolean? @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  @@id([base_id, id])
  @@unique([fk_automation_id, fk_user_id], map: "nc_automation_subscribers_unique_idx")
  @@index([fk_automation_id], map: "nc_automation_subscribers_automation_idx")
  @@index([fk_user_id], map: "nc_automation_subscribers_user_idx")
}

model nc_automations {
  id              String   @db.VarChar(20)
  title           String?  @db.VarChar(255)
  description     String?
  meta            String?
  fk_workspace_id String?  @db.VarChar(20)
  base_id         String   @db.VarChar(20)
  order           Float?   @db.Real
  type            String?  @db.VarChar(20)
  created_by      String?  @db.VarChar(20)
  updated_by      String?  @db.VarChar(20)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  enabled         Boolean? @default(false)
  nodes           String?
  edges           String?
  draft           String?
  config          String?
  script          String?

  @@id([base_id, id])
  @@index([base_id, fk_workspace_id], map: "nc_automations_context_idx")
  @@index([enabled])
  @@index([id], map: "nc_automations_oldpk_idx")
  @@index([base_id, order], map: "nc_automations_order_idx")
  @@index([type])
}

model nc_base_users_v2 {
  base_id         String    @db.VarChar(20)
  fk_user_id      String    @db.VarChar(20)
  roles           String?
  starred         Boolean?
  pinned          Boolean?
  group           String?   @db.VarChar(255)
  color           String?   @db.VarChar(255)
  order           Float?    @db.Real
  hidden          Float?    @db.Real
  opened_date     DateTime? @db.Timestamptz(6)
  invited_by      String?   @db.VarChar(20)
  fk_workspace_id String?   @db.VarChar(20)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)

  @@id([base_id, fk_user_id])
  @@index([base_id, fk_workspace_id], map: "nc_base_users_v2_base_id_fk_workspace_id_index")
  @@index([invited_by], map: "nc_base_users_v2_invited_by_index")
  @@index([fk_user_id], map: "nc_project_users_v2_fk_user_id_index")
}

model nc_bases_v2 {
  id                     String   @id(map: "nc_projects_v2_pkey") @db.VarChar(128)
  title                  String?  @db.VarChar(255)
  prefix                 String?  @db.VarChar(255)
  status                 String?  @db.VarChar(255)
  description            String?
  meta                   String?
  color                  String?  @db.VarChar(255)
  uuid                   String?  @db.VarChar(255)
  password               String?  @db.VarChar(255)
  roles                  String?  @db.VarChar(255)
  deleted                Boolean? @default(false)
  is_meta                Boolean?
  order                  Float?   @db.Real
  type                   String?  @db.VarChar(200)
  fk_workspace_id        String?  @db.VarChar(20)
  is_snapshot            Boolean? @default(false)
  fk_custom_url_id       String?  @db.VarChar(20)
  version                Int?     @default(2) @db.SmallInt
  default_role           String?  @db.VarChar(20)
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @default(now()) @db.Timestamptz(6)
  managed_app_master     Boolean? @default(false)
  managed_app_id         String?  @db.VarChar(20)
  managed_app_version_id String?  @db.VarChar(20)
  auto_update            Boolean? @default(true)
  is_sandbox_master      Boolean? @default(false)
  is_sandbox             Boolean? @default(false)

  @@index([is_sandbox], map: "nc_bases_is_sandbox_idx")
  @@index([is_sandbox_master], map: "nc_bases_is_sandbox_master_idx")
  @@index([managed_app_id, auto_update], map: "nc_bases_managed_app_auto_update_idx")
  @@index([managed_app_id], map: "nc_bases_managed_app_id_idx")
  @@index([managed_app_master], map: "nc_bases_managed_app_master_idx")
  @@index([managed_app_version_id], map: "nc_bases_managed_app_version_id_idx")
  @@index([fk_custom_url_id], map: "nc_bases_v2_fk_custom_url_id_index")
  @@index([fk_workspace_id], map: "nc_bases_v2_fk_workspace_id_index")
}

model nc_calendar_view_columns_v2 {
  id              String   @db.VarChar(20)
  base_id         String   @db.VarChar(20)
  source_id       String?  @db.VarChar(20)
  fk_view_id      String?  @db.VarChar(20)
  fk_column_id    String?  @db.VarChar(20)
  show            Boolean?
  bold            Boolean?
  underline       Boolean?
  italic          Boolean?
  order           Float?   @db.Real
  fk_workspace_id String?  @db.VarChar(20)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

