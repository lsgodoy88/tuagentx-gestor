  roles            String?   @db.VarChar(255)
  invite_token     String?   @db.VarChar(255)
  invite_accepted  Boolean?  @default(false)
  deleted          Boolean?  @default(false)
  deleted_at       DateTime? @db.Timestamptz(6)
  order            Float?    @db.Real
  invited_by       String?   @db.VarChar(20)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)
  scim_external_id String?   @db.VarChar(255)
  scim_managed     Boolean?  @default(false)
  scim_user_name   String?   @db.VarChar(255)
  scim_meta        String?

  @@id([fk_workspace_id, fk_user_id])
  @@index([scim_external_id], map: "nc_workspace_user_scim_external_id_idx")
  @@index([scim_managed], map: "nc_workspace_user_scim_managed_idx")
  @@index([invited_by], map: "workspace_user_invited_by_index")
}

model xc_knex_migrationsv0 {
  id             Int       @id @default(autoincrement())
  name           String?   @db.VarChar(255)
  batch          Int?
  migration_time DateTime? @db.Timestamptz(6)
}

model xc_knex_migrationsv0_lock {
  index     Int  @id @default(autoincrement())
  is_locked Int?
}

model MetaRecaudo {
  id          String   @id @default(cuid())
  empleadoId  String
  empresaId   String
  mes         Int      // 1-12
  anio        Int
  metaPesos   Decimal  @db.Decimal(14, 2)
  metaPct     Decimal? @db.Decimal(5, 2)  // % de cartera asignada
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  empleado    Empleado @relation(fields: [empleadoId], references: [id])
  empresa     Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empleadoId, mes, anio])
  @@map("MetaRecaudo")
}
model SubEmpresa {
  id            String        @id @default(cuid())
  empresaId     String
  nombre        String
  activa        Boolean       @default(true)
  configRecibos Json?         @default("{\"nit\": null, \"logo\": null, \"prefijo\": \"REC\", \"telefono\": null, \"direccion\": null, \"anchoPapel\": \"80mm\"}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  empleados     Empleado[]
  clientes      Cliente[]
  rutas         Ruta[]
  rutasFijas    RutaFija[]
  integraciones Integracion[]
  @@index([empresaId])
  @@map("SubEmpresa")
}

model Integracion {
  id           String       @id @default(cuid())
  empresaId    String
  subEmpresaId String?
  nombre       String
  tipo         String       // uptres | siigo | alegra | custom
  activa       Boolean      @default(true)
  config       Json?        // credenciales encriptadas, URLs base, etc.
  ultimaSync   DateTime?
  syncInicial  Boolean   @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  subEmpresa   SubEmpresa?  @relation(fields: [subEmpresaId], references: [id])
  compras      SyncCompra[]
  deudas       SyncDeuda[]
  logs         SyncLog[]
  carteraCache CarteraCache[]
  @@index([empresaId])
  @@index([subEmpresaId])
  @@map("Integracion")
}

model CarteraCache {
  id                  String    @id @default(cuid())
  empresaId           String
  integracionId       String
  clienteId           String?   // FK a Cliente local (null si no existe aun)
  clienteApiId        String    // ID en UpTres
  nombre              String
  nit                 String?
  telefono            String?
  ciudad              String?
  empleadoExternalId  String?
  empleadoNombre      String?
  saldoTotal          Decimal   @db.Decimal(14, 2)
  saldoPendiente      Decimal   @db.Decimal(14, 2)
  porEstado           Json?     // {pendiente, vencida, mora, critica, pagada}
  deudas              Json?     // array detalle de cada orden
  totalDeudas         Int       @default(0)
  ultimaActualizacion DateTime  @default(now())
  ultimaConsulta      DateTime?
  saldoValidado       Boolean   @default(false)

  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  integracion Integracion  @relation(fields: [integracionId], references: [id])

  @@unique([integracionId, clienteApiId])
  @@index([empresaId])
  @@index([clienteId])
  @@index([integracionId])
  @@map("CarteraCache")
}

model SyncCompra {
  id                  String      @id @default(cuid())
  integracionId       String
  externalId          String      // uid/_id de UpTres
  clienteApiId        String      // cliente.uid de UpTres = Cliente.apiId
  empleadoExternalId  String?     // empleado.uid de UpTres
  numeroOrden         Int?
  numeroFactura       Int?
  valor               Decimal     @db.Decimal(14, 2)
  saldo               Decimal     @default(0) @db.Decimal(14, 2)
  abono               Decimal     @default(0) @db.Decimal(14, 2)
  tipo                String?     // credito | contado
  diasCredito         Int?
  facturado           Boolean     @default(false)
  fecha               DateTime?
  fechaVencimiento    DateTime?
  nameciudad          String?
  condition           Boolean     @default(true)
  data                Json?       // JSON crudo completo del externo
  modificadoEn        DateTime?   // fModificado del externo para delta sync
  sincronizadoEl      DateTime    @default(now())
  integracion         Integracion @relation(fields: [integracionId], references: [id])
  @@unique([integracionId, externalId])
  @@index([clienteApiId])
  @@index([integracionId])
  @@map("SyncCompra")
}

model SyncDeuda {
  id               String      @id @default(cuid())
  integracionId    String
  externalId       String      // uid de la orden de credito en UpTres
  clienteApiId     String      // cliente.uid = Cliente.apiId
  empleadoExternalId String?
  numeroOrden      Int?
  numeroFactura    Int?
  valor            Decimal     @db.Decimal(14, 2)
  saldo            Decimal     @db.Decimal(14, 2)
  saldoAnterior    Decimal?    @db.Decimal(14, 2)
  abono            Decimal     @default(0) @db.Decimal(14, 2)
  diasCredito      Int?
  fechaVencimiento DateTime?
  condition        Boolean     @default(true)
  data             Json?       // JSON crudo completo del externo
  modificadoEn     DateTime?
  sincronizadoEl   DateTime    @default(now())
  integracion      Integracion @relation(fields: [integracionId], references: [id])
  @@unique([integracionId, externalId])
  @@index([clienteApiId])
  @@index([integracionId])
  @@map("SyncDeuda")
}

model SyncLog {
  id                   String      @id @default(cuid())
  integracionId        String
  inicio               DateTime
  fin                  DateTime?
  clientesActualizados Int         @default(0)
  comprasSincronizadas Int         @default(0)
  deudasSincronizadas  Int         @default(0)
  errores              Json?
  estado               String      @default("ok") // ok | parcial | error
  createdAt            DateTime    @default(now())
  integracion          Integracion @relation(fields: [integracionId], references: [id])
  @@index([integracionId])
  @@map("SyncLog")
}


model EmpresaVinculada {
  id                String         @id @default(cuid())
  empresaId         String
  nombre            String
  apiKey            String         @unique @default(cuid())
  color             String         @default("#8b5cf6")
  activa            Boolean        @default(true)
  empresaClienteId  String?
  createdAt         DateTime       @default(now())
  empresa           Empresa        @relation(fields: [empresaId], references: [id])
  rutas             Ruta[]
  ordenesDespacho   OrdenDespacho[]
  @@map("EmpresaVinculada")
}

model OrdenDespacho {
  id                String    @id @default(cuid())
  empresaId         String
  origen            String
  origenId          String?
  numeroOrden       String
  clienteNombre     String
  clienteNit        String?
  ciudad            String?
  direccion         String?
  telefono          String?
  estado            String    @default("pendiente")
  fotoAlistamiento  String?   // legacy
  fotosAlistamiento Json?     // array de URLs
  alistadoEl        DateTime?
  alistadoPorId     String?
  repartidorId      String?
  firmaEntrega      String?
  fotoEntrega       String?
  entregadoEl       DateTime?
  transportadora    String?
  guiaTransporte    String?
  fechaOrden        DateTime?
  origenVinculadaId String?
  createdAt         DateTime  @default(now())
  empresaVinculada  EmpresaVinculada? @relation(fields: [origenVinculadaId], references: [id])
  updatedAt         DateTime  @updatedAt
  empresa           Empresa   @relation(fields: [empresaId], references: [id])
  alistadoPor       Empleado? @relation("AlistadoPor", fields: [alistadoPorId], references: [id])
  repartidor        Empleado? @relation("RepartidorDespacho", fields: [repartidorId], references: [id])
  visitas           Visita[]
  @@index([empresaId, estado])
  @@index([empresaId, origen])
  @@map("OrdenDespacho")
}
